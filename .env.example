VITE_APP_NAME=Meeting Brain
# Set to true to force mock/fallback report generation and skip Gemini requests entirely.
FORCE_FALLBACK=true
# Leave blank to use fallback/mock report generation in local development.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Leave blank to disable live email delivery in local development.
RESEND_API_KEY=
EMAIL_FROM=Meeting Brain <reports@example.com>
